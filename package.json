{
  "name": "dormjs",
  "version": "0.0.1",
  "description": "A Django-style ORM for Node.js — declarative models, a lazy chainable QuerySet, and a manage-style CLI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "dorm": "./bin/dorm.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "node --test --disable-warning=ExperimentalWarning 'test/**/*.test.ts'",
    "test:watch": "node --test --watch --disable-warning=ExperimentalWarning 'test/**/*.test.ts'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run clean && npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "orm",
    "django",
    "queryset",
    "migrations",
    "sqlite",
    "postgres",
    "mysql"
  ],
  "license": "MIT",
  "author": "Rohan Singh <rohansingh9001@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rohansingh9001/dormjs.git"
  },
  "homepage": "https://github.com/rohansingh9001/dormjs#readme",
  "bugs": {
    "url": "https://github.com/rohansingh9001/dormjs/issues"
  },
  "peerDependencies": {
    "mysql2": ">=3",
    "pg": ">=8"
  },
  "peerDependenciesMeta": {
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
